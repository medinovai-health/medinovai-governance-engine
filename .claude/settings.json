{
  "model": "claude-opus-4-6",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(git clean -fd)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker compose down -v*)",
      "Bash(docker compose down --volumes*)",
      "Bash(kubectl delete *)",
      "Bash(sudo *)"
    ]
  }
}
